# ─── Database ────────────────────────────────────────────────────────────────
# MongoDB connection string (MongoDB Atlas recommended for production)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/smartbuy

# ─── Cache ────────────────────────────────────────────────────────────────────
# Redis connection URL. Omit to disable caching (falls back gracefully).
# Recommended: Upstash Redis (free tier available at upstash.com)
REDIS_URL=redis://default:password@your-redis-host:6379

# ─── Site ─────────────────────────────────────────────────────────────────────
# Public URL of your deployed site — used for canonical URLs, OG tags, sitemap
SITE_URL=https://yourdomain.com

# ─── Admin ────────────────────────────────────────────────────────────────────
# Secret key to protect the admin panel. Use a long random string.
# Generate one: openssl rand -hex 32
ADMIN_KEY=change-me-generate-with-openssl-rand-hex-32

# ─── Amazon Associates (PA-API v5) ────────────────────────────────────────────
# Required only for Amazon product import and price refresh features.
# Apply at: affiliate-program.amazon.com → Tools → Product Advertising API
AMAZON_ACCESS_KEY=your-paapi-access-key
AMAZON_SECRET_KEY=your-paapi-secret-key
AMAZON_PARTNER_TAG=your-associate-tag-20

# Amazon region — must match your Associates account region
# Options: us-east-1 | eu-west-1 | ap-southeast-1 | ap-northeast-1
AMAZON_REGION=us-east-1

# Amazon marketplace domain for your region
# Options: www.amazon.com | www.amazon.co.uk | www.amazon.sg | www.amazon.co.jp
AMAZON_MARKETPLACE=www.amazon.com

# ─── eBay Partner Network ─────────────────────────────────────────────────────
# Required for eBay product import.
# 1. Create a developer account at developer.ebay.com (free)
# 2. Create an app → get Client ID and Client Secret (use Production keys)
# 3. Join eBay Partner Network at partnernetwork.ebay.com → get Campaign ID
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret
EBAY_CAMPAIGN_ID=your-epn-campaign-id

# ─── Best Buy (Products API + CJ Affiliate) ───────────────────────────────────
# 1. Get free API key at developer.bestbuy.com
# 2. Join Best Buy affiliate program via CJ Affiliate (cj.com) → get Publisher ID
BESTBUY_API_KEY=your-bestbuy-api-key
BESTBUY_CJ_PUBLISHER_ID=your-cj-publisher-id

# ─── Walmart (via Impact affiliate platform) ──────────────────────────────────
# 1. Create publisher account at impact.com (free)
# 2. Apply to Walmart's affiliate program on Impact → get approved
# 3. Account SID and Auth Token: Impact dashboard → Settings → API
# 4. Catalog ID: Impact dashboard → Brands → Walmart → Catalog ID
WALMART_IMPACT_SID=your-impact-account-sid
WALMART_IMPACT_AUTH=your-impact-auth-token
WALMART_IMPACT_CATALOG_ID=your-walmart-catalog-id
